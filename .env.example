# LLM provider — pick one of the options below, uncomment, and fill in the key.
# Any OpenAI-compatible provider works.

# --- Option 1: Ollama (fully local, no signup, no cost, no data leaves your machine) ---
# Install: https://ollama.com  then: ollama pull llama3.2
# HONEST_REVIEWS_LLM_BASE_URL=http://localhost:11434/v1
# HONEST_REVIEWS_LLM_API_KEY=ollama
# HONEST_REVIEWS_LLM_MODEL=llama3.2

# --- Option 2: Groq (free tier, fast, cloud) ---
# Get key: https://console.groq.com → API Keys
# HONEST_REVIEWS_LLM_BASE_URL=https://api.groq.com/openai/v1
# HONEST_REVIEWS_LLM_API_KEY=gsk_...
# HONEST_REVIEWS_LLM_MODEL=llama-3.3-70b-versatile

# --- Option 3: OpenAI ---
# Get key: https://platform.openai.com/api-keys
# HONEST_REVIEWS_LLM_BASE_URL=https://api.openai.com/v1
# HONEST_REVIEWS_LLM_API_KEY=sk-...
# HONEST_REVIEWS_LLM_MODEL=gpt-4o-mini

# Optional: override stale claim threshold (days)
MAX_CLAIM_AGE_DAYS=90
